<launch>
  <!-- Week 10 robot model: TurtleBot3 Waffle Pi with camera support -->
  <arg name="model" default="waffle_pi"/>

  <!-- Spawn position: adjust x and y later after testing -->
  <arg name="x_pos" default="1.3052"/>
  <arg name="y_pos" default="6.10"/>
  <arg name="z_pos" default="0.05"/>
  <arg name="yaw" default="1.57"/>

  <param name="robot_description"
         command="$(find xacro)/xacro --inorder '$(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro'" />

  <node pkg="gazebo_ros"
        type="spawn_model"
        name="spawn_turtlebot3_waffle_pi"
        args="-urdf -model turtlebot3_waffle_pi -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -Y $(arg yaw) -param robot_description"
        output="screen" />
</launch>
