    <!-- HOME / CHARGING STATION -->
    <model name="home_charging_station_A213696">
      <static>true</static>
      <pose>-1.3052 6.8435 0.03 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.20 1.20 0.06</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.20 1.20 0.06</size></box></geometry>
          <material><ambient>0.0 0.2 1.0 1</ambient><diffuse>0.0 0.2 1.0 1</diffuse></material>
        </visual>
      </link>
    </model>

