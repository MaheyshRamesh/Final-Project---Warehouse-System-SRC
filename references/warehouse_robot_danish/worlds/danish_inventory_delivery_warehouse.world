    <!-- =============================================================== -->
    <!-- Danish Group Custom Add-ons: Inventory + Delivery Requirements -->
    <!-- These extra objects make the world match the project concept:   -->
    <!-- Autonomous Warehouse Inventory and Item Delivery Robot.         -->
