<launch>
  <arg name="gui" default="true"/>
  <arg name="robot" default="steel"/> <!-- Steel has arm and parallel gripper -->

  <!-- Include the main TIAGo Gazebo simulation launcher -->
  <include file="$(find tiago_gazebo)/launch/tiago_gazebo.launch">
    <arg name="world" value="danish_inventory_delivery_warehouse"/>
    <arg name="robot" value="$(arg robot)"/>
    <arg name="public_sim" value="true"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="gzpose" value="-x -5.00 -y 3.00 -z 0.05 -R 0.0 -P 0.0 -Y 0.0"/>
  </include>
</launch>
